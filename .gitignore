
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# External cloned repos for ecosystem audit / reference reading.
# Keep the parent dir for the empirical-probe scripts (external/probes/),
# but skip the upstream clones — they are reproducible via shallow clone.
external/Arblib.jl/
external/Polynomials.jl/
external/TaylorIntegration.jl/
external/TaylorSeries.jl/
external/chebfun/
external/DMSUITE/

# Marker page-image extractions — keep the .md files, skip the bulky .jpeg.
references/markdown/**/*.jpeg

# Generated example plots — regenerable via `julia --project=examples examples/<name>.jl`.
examples/*.png
examples/*.svg
examples/*.pdf
# Exception: the README hero image is a committed doc asset.
!examples/tritronquee_heatmap.png

# Documenter build output + per-environment manifest — regenerable via
# `julia --project=docs docs/make.jl`.
docs/build/
docs/Manifest.toml

# Figure-reproduction project — per-environment manifest is regenerable
# via `julia --project=figures -e 'using Pkg; Pkg.instantiate()'`.
# The output PNGs ARE committed: they are the figure deliverables.
figures/Manifest.toml

# Local scheduling lockfiles.
.claude/scheduled_tasks.lock
